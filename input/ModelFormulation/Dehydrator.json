{
  "Python Category": "MajorEquipment",
  "Python Class":    "MEETDehydrator",
  "Readable Name":   "Glycol Dehydrator",

  "Description": "Dehydrator model with flash tank and still vent column",
  "Fluid Flows": [
      {"Fluid": "Contactor_Flow", "secondary_id": "", "description": "Output flow from dehydrator (dry gas) to gas sales"},
      {"Fluid": "Flash_Tank_Flow", "secondary_id": "", "description": "Output flow from dehydrator to flash tank separators"},
      {"Fluid": "Still_Vent_Flow", "secondary_id": "", "description": "Output flow from dehydrator to still column vent (reboiler)"}
  ],
  "States": [
	{"stateName": "OPERATING", "description": "Dehydrator operating normally"}
  ],
  "StateMachineDiagram": "graphics/OneStateSM.png",

  "Reference": "reference/DehyRef.rst",

  "Model Parameters": [
	{		                                				"Python Parameter": "modelCategory",              "Parameter Type": "Constant", "Value":"Dehydrator"},
    {		                                				"Python Parameter": "modelSubcategory",           "Parameter Type": "Constant", "Value":"Glycol"},
    {"Model Parameter": "Facility ID",      				"Python Parameter": "facilityID",                 "Parameter Type": "Sheet"},
	{"Model Parameter": "Unit ID",          				"Python Parameter": "unitID",                     "Parameter Type": "Sheet"},
    {"Model Parameter": "Glycol Type",      				"Python Parameter": "glycolType",                 "Parameter Type": "Sheet"},
    {"Model Parameter": "Glycol Pump", 				        "Python Parameter": "glycolPump",                 "Parameter Type": "Sheet"},
    {"Model Parameter": "Flash Tank",      	 				"Python Parameter": "flashTank",                  "Parameter Type": "Sheet"},
    {"Model Parameter": "Operating Hours",          		"Python Parameter": "operatingHours",             "Parameter Type": "Sheet"},
    {"Model Parameter": "Lean Glycol Circulation Ratio",    "Python Parameter": "leanGlycolCirculationRatio", "Parameter Type": "Sheet"},
    {"Model Parameter": "Wet Gas Flow Rate",          		"Python Parameter": "wetGasFlowRate",             "Parameter Type": "Sheet"},
    {"Model Parameter": "Wet Gas Temperature",          	"Python Parameter": "wetGasTemperature",          "Parameter Type": "Sheet"},
    {"Model Parameter": "Wet Gas Pressure",          		"Python Parameter": "wetGasPressure",             "Parameter Type": "Sheet"},
    {"Model Parameter": "Lean Glycol Circulation Rate",     "Python Parameter": "leanGlycolCirculationRate",  "Parameter Type": "Sheet"},
    {"Model Parameter": "Stripping Gas Flow Rate",          "Python Parameter": "strippingGasFlowRate",       "Parameter Type": "Sheet"},
    {"Model Parameter": "Tank Flash Controlled Flag",       "Python Parameter": "tankFlashControlledFlag",    "Parameter Type": "Sheet"},
    {"Model Parameter": "Still Vent Controlled Flag",       "Python Parameter": "stillVentControlledFlag",    "Parameter Type": "Sheet"},
    {"Model Parameter": "Glycol Pump Injection Ratio",      "Python Parameter": "glycolPumpInjectionRatio",   "Parameter Type": "Sheet"}
