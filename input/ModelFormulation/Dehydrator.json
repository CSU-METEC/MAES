    },
    {"Python Category": "Emitter", "Python Class": "MEETFFEmitter", "Readable Name": "Still Vent Emissions", "Category": "STILL VENT EMITTER", "Emission Category": "VENTED",
		 "Model Parameters": [
           {"Python Parameter": "statesActive",     "Parameter Type": "Constant", "Value": "OPERATING"},
           {"Python Parameter": "instanceFormat",   "Parameter Type": "Constant", "Value": "{unitID}_dehy_still_vent_{serialNo}"},
           {"Python Parameter": "secondaryID",      "Parameter Type": "Constant", "Value": "still_vent_emissions"},
           {"Model Parameter": "Still Vent Controlled Flag",  "Python Parameter": "instantiationVal", "Parameter Type": "Sheet"},
           {                                                 "Python Parameter": "valsForInstantiation", "Parameter Type": "Constant", "Value": "False"}
         ]
    }
	]
}
