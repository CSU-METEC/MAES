           {                                                 "Python Parameter": "valsForInstantiation", "Parameter Type": "Constant", "Value": "False"}
         ]
    },
   {"Python Category": "Emitter", "Python Class": "MEETFFEmitter", "Readable Name": "Glycol Pump Still Vent Emissions", "Category": "GLYCOL PUMP EMITTER", "Emission Category": "VENTED",
       "Model Parameters": [
