           {                                                 "Python Parameter": "valsForInstantiation", "Parameter Type": "Constant", "Value": "False"}
         ]
    },
    {"Python Category": "Emitter", "Python Class": "MEETFFEmitter", "Readable Name": "Glycol Pump Tank Flash Emissions", "Category": "GLYCOL PUMP EMITTER", "Emission Category": "VENTED",
		 "Model Parameters": [
           {"Python Parameter": "statesActive",     "Parameter Type": "Constant", "Value": "OPERATING"},
           {"Python Parameter": "instanceFormat",   "Parameter Type": "Constant", "Value": "{unitID}_dehy_glycol_pump_{serialNo}"},
           {"Python Parameter": "secondaryID",   "Parameter Type": "Constant", "Value": "gycol_pump_flash_tank_emissions"},
