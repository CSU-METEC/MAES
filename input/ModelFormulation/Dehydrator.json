         {"Model Parameter": "Still Vent Controlled Flag",  "Python Parameter": "instantiationVal", "Parameter Type": "Sheet"},
         {                                                 "Python Parameter": "valsForInstantiation", "Parameter Type": "Constant", "Value": "False"}
       ]
    },
    {"Python Category": "Emitter", "Python Class": "MEETFFEmitter", "Readable Name": "Stripping Gas Emissions", "Category": "STRIPPING GAS EMITTER", "Emission Category": "VENTED",
       "Model Parameters": [
         {"Python Parameter": "statesActive",     "Parameter Type": "Constant", "Value": "OPERATING"},
         {"Python Parameter": "instanceFormat",   "Parameter Type": "Constant", "Value": "{unitID}_stripping_gas_emissions_{serialNo}"},
